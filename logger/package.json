{
  "name": "@hopae/logger",
  "version": "0.1.0",
  "description": "Structured, trace-correlated logging for Node/TypeScript microservices (OpenTelemetry-aligned).",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./http": {
      "types": "./dist/http/index.d.ts",
      "import": "./dist/http/index.js",
      "require": "./dist/http/index.cjs"
    },
    "./nestjs": {
      "types": "./dist/nestjs/index.d.ts",
      "import": "./dist/nestjs/index.js",
      "require": "./dist/nestjs/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "demo": "tsx examples/trace-demo.ts",
    "demo:nest": "tsx examples/nestjs-trace-demo.ts"
  },
  "dependencies": {
    "pino": "^9.5.0"
  },
  "peerDependencies": {
    "@nestjs/common": ">=9",
    "rxjs": ">=7"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    },
    "rxjs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nestjs/common": "^10.4.4",
    "@nestjs/core": "^10.4.22",
    "@nestjs/platform-express": "^10.4.22",
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.4",
    "express": "^4.21.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "tsup": "^8.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
